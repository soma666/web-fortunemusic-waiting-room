{
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/history", "destination": "/api/history" },
    { "source": "/api/collector-diag", "destination": "/api/collector-diag" }
  ],
  "functions": {
    "api/history.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/collect-history.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/collector-diag.ts": {
      "memory": 512,
      "maxDuration": 10
    }
  }
}